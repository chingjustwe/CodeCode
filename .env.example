# ── Provider & API Key ──────────────────────────────────────────
# Choose LLM provider: anthropic (default) | claude | openai | deepseek | minimax | kimi | glm
LLM_PROVIDER=anthropic

# Your API key (any of the following is fine)
# LLM_API_KEY=your_API_Key_here                  (general fallback)
ANTHROPIC_API_KEY=your_Anthropic_API_Key_here
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# MINIMAX_API_KEY=sk-xxx
# KIMI_API_KEY=sk-xxx
# GLM_API_KEY=sk-xxx

# ── Optional: specify model ──────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514

# ── Optional: CodeCode working directory ─────────────────────────
# CODEDIR=.my-codecode

# ── Optional: override context window (for token % display) ────
# LLM_CONTEXT_WINDOW=200000

# ── OpenRouter (requires codecode.yml) ──────────────────────────
# To use OpenRouter, set LLM_PROVIDER=openrouter and add the
# provider config in codecode.yml. LLM_API_KEY or OPENROUTER_API_KEY
# can be used as the API key.
# OPENROUTER_API_KEY=sk-or-v1-xxx
