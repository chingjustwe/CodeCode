# ── Provider & API Key ──────────────────────────────────────────
# 选择 LLM 提供商: anthropic (default) | claude | openai | deepseek | minimax | kimi
LLM_PROVIDER=anthropic

# 你的 API Key（下面任意一个即可）
# LLM_API_KEY=你的API_Key_在这里                  （通用 fallback）
ANTHROPIC_API_KEY=你的Anthropic_API_Key_在这里
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# MINIMAX_API_KEY=sk-xxx
# KIMI_API_KEY=sk-xxx

# ── 可选：指定模型 ─────────────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514